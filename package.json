  "description": "Pi extension that requests OpenAI's priority service tier (Fast Mode) for GPT-5.4 / GPT-5.5, with subagent hand-off.",
  "license": "MIT",
  "type": "module",
  "author": "devwithpug",
  "keywords": [
    "pi-package",
    "pi-extension",
    "openai",
    "fast-mode",
    "service-tier",
    "priority"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devwithpug/pi-openai-fastmode.git"
  },
  "files": [
    "index.ts",
    "src",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "check": "npm run typecheck && npm test"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  }
